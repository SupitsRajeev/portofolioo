<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500" width="400" height="500">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e1b4b;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#312e81;stop-opacity:1"/>
    </linearGradient>
    <linearGradient id="avatar" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:0.4"/>
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.4"/>
    </linearGradient>
  </defs>
  <rect width="400" height="500" fill="url(#bg)"/>
  <!-- Body -->
  <ellipse cx="200" cy="420" rx="140" ry="80" fill="url(#avatar)"/>
  <!-- Head -->
  <circle cx="200" cy="200" r="90" fill="url(#avatar)"/>
  <!-- Silhouette lines -->
  <text x="200" y="480" text-anchor="middle" fill="rgba(255,255,255,0.3)" font-family="monospace" font-size="12">Replace with your photo</text>
</svg>
