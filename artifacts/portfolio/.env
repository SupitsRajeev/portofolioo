# Admin credentials for the portfolio CMS
# Change VITE_ADMIN_USER and regenerate VITE_ADMIN_PASS_HASH for production use.
# To generate a new hash: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
VITE_ADMIN_USER=admin
# SHA-256 hash of: admin123
VITE_ADMIN_PASS_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9

# API server used by the CMS-backed portfolio content
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Analytics ────────────────────────────────────────────────────────────────
# Yandex Metrica counter ID  (e.g. 12345678)
# Leave empty to disable Yandex Metrica tracking.
NEXT_PUBLIC_YANDEX_METRICA_ID=

# Google Analytics 4 Measurement ID  (e.g. G-XXXXXXXXXX)
# Leave empty to disable Google Analytics tracking.
NEXT_PUBLIC_GA_ID=
